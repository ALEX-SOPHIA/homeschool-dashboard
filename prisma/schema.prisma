generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // We removed the URL here to comply with (遵循) Prisma V7 standards
}

// 1. The Tenant (租户)
model Family {
  id        String    @id @default(uuid())
  name      String    // e.g., "The Smith Family"
  createdAt DateTime  @default(now())
  
  // A family can have multiple children (One-to-many relationship / 一对多关联)
  students  Student[]
}

// 2. The Child/User (子用户)
model Student {
  id        String    @id @default(uuid())
  name      String
  avatar    String?   // The '?' means this field is optional (可选字段)
  
  // Foreign Key (外键) linking to the Family table
  familyId  String
  family    Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  
  // A student has many tasks
  tasks     Task[]

  // A student owns a collection of course templates
  templates CourseTemplate[]
}

// 3. The Assignment (学习任务)
model Task {
  id             String        @id @default(uuid())
  title          String
  
  // 👇 MODIFICATION 1: Default category for ad-hoc tasks
  subject        String        @default("General")
  
  // 👇 MODIFICATION 2: Changed from String? to Int (always store minutes!)
  targetDuration Int           @default(0)
  
  // 👇 MODIFICATION 3: The exact time spent
  actualDuration Int           @default(0)
  
  status         String        @default("pending") // "pending", "in_progress", or "completed"
  
  // 👇 MODIFICATION 4: Time-series timestamp for the semester review
  completedAt    DateTime?
  
  // Foreign Key linking to the Student table
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  // A task can have multiple timer sessions logged against it
  timeSessions   TimeSession[]
}

// 4. The Analytics Ledger (数据流水账)
model TimeSession {
  id              String    @id @default(uuid())
  startTime       DateTime  @default(now())
  endTime         DateTime? // Nullable (可为空的), because a timer might still be running
  durationMinutes Int?      // Calculated upon completion (完成时计算)
  
  // Foreign Key linking to the Task table
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// 5. The Template Engine (课程预设胶囊)
model CourseTemplate {
  id              String   @id @default(uuid())
  title           String   // e.g., "English Reading"
  subject         String   @default("General") // e.g., "English"
  color           String   @default("#3b82f6") // Stores the UI color code
  defaultDuration Int      @default(30) // Default planned minutes
  
  // Foreign Key linking to the Student table
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
}